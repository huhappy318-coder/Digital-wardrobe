{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "^/(.+\\.html)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "^/(.+\\.css)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "^/(.+\\.js)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": ".*",
      "dest": "/frontend/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  }
}
