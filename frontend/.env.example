# 环境变量示例配置
# 在Vercel部署时，请设置以下环境变量

# API 基础URL
# 本地开发: http://localhost:8001
# 生产环境: https://your-backend-service.vercel.app
NEXT_PUBLIC_API_URL=

# AI 模型配置
NEXT_PUBLIC_DEEPSEEK_API_URL=https://api.deepseek.com/v1
NEXT_PUBLIC_QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NEXT_PUBLIC_DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
NEXT_PUBLIC_KIMI_API_URL=https://api.moonshot.cn/v1

# AI 模型名称
NEXT_PUBLIC_DEEPSEEK_MODEL=deepseek-chat
NEXT_PUBLIC_QWEN_MODEL=qwen-plus
NEXT_PUBLIC_DOUBAO_MODEL=doubao-pro-4k
NEXT_PUBLIC_KIMI_MODEL=moonshot-v1-8k