{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/(.+\\.html)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.+\\.css)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.+\\.js)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/public/assets/$1"
    }
  ]
}